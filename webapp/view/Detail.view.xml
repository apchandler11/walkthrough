<mvc:View xmlns:mvc="sap.ui.core.mvc"
    controllerName="demo.walkthrough.controller.Detail"
    xmlns="sap.m"
    xmlns:wt="demo.walkthrough.control">
    <Page title="{i18n>detailPageTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack">
        <ObjectHeader title="{invoice>ProductName}"
            intro="{invoice>ShipperName}" />
        <wt:ProductRating id="rating" class="sapUiSmallMarginBeginEnd" 
            change=".onRatingChange" />
    </Page>
</mvc:View>